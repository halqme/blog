{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "halqme",
  "compatibility_date": "2026-05-10",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "0w0.foo",
      "custom_domain": true
    },
    {
      "pattern": "www.0w0.foo",
      "custom_domain": true
    }
  ]
}
